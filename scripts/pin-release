#!/usr/bin/env -S clojure -M

(require '[clojure.java.io :as io]
         '[clojure.java.shell :refer [sh]]
         '[clojure.string :as str])

(defn usage []
  (println "Usage:")
  (println "  pin-release <tag> [sha]")
  (println)
  (println "Creates git tag <tag> on [sha] (or HEAD when omitted)")
  (println "and pushes it to origin.")
  (println "Updates skills/snlib-cli/scripts/snlib-cli so its default")
  (println "SNLIB_GIT_TAG and SNLIB_GIT_SHA point at the selected release commit."))

(defn sh!
  [& args]
  (let [{:keys [exit out err]} (apply sh args)]
    (when-not (zero? exit)
      (binding [*out* *err*]
        (print err))
      (System/exit exit))
    (str/trim out)))

(defn quoted
  [s]
  (java.util.regex.Matcher/quoteReplacement s))

(let [[tag sha & extra] *command-line-args*]
  (cond
    (#{"-h" "--help"} tag)
    (usage)

    (or (nil? tag) (seq extra))
    (do
      (binding [*out* *err*]
        (usage))
      (System/exit 2))

    :else
    (let [target (or sha "HEAD")
          sha (sh! "git" "rev-parse" "--verify" (str target "^{commit}"))
          _ (sh! "git" "tag" tag sha)
          _ (sh! "git" "push" "origin" tag)
          repo-root (.getParentFile (.getParentFile (io/file *file*)))
          launcher (io/file repo-root "skills" "snlib-cli" "scripts" "snlib-cli")
          updated (-> (slurp launcher)
                      (str/replace #"(?m)^SNLIB_GIT_TAG=.*$"
                                   (quoted (format "SNLIB_GIT_TAG=\"${SNLIB_GIT_TAG:-%s}\"" tag)))
                      (str/replace #"(?m)^SNLIB_GIT_SHA=.*$"
                                   (quoted (format "SNLIB_GIT_SHA=\"${SNLIB_GIT_SHA:-%s}\"" sha))))]
      (spit launcher updated)
      (println (str "Created and pushed tag " tag))
      (println (str "Updated " (.getPath launcher)))
      (println (str "  SNLIB_GIT_TAG=" tag))
      (println (str "  SNLIB_GIT_SHA=" sha)))))
