#!/usr/bin/env bash
set -euo pipefail

SNLIB_GROUP="${SNLIB_GROUP:-io.github.ruseel}"
SNLIB_ARTIFACT="${SNLIB_ARTIFACT:-snlib-cli}"
SNLIB_VERSION="${SNLIB_VERSION:-0.1.0}"

if ! command -v clojure >/dev/null 2>&1; then
  echo "ERROR: clojure command not found. Install Clojure CLI first." >&2
  exit 127
fi

if ! command -v java >/dev/null 2>&1; then
  echo "ERROR: java command not found. Install a JDK first." >&2
  exit 127
fi

deps_edn="{:deps {${SNLIB_GROUP}/${SNLIB_ARTIFACT} {:mvn/version \"${SNLIB_VERSION}\"}}}"

exec clojure -Sdeps "$deps_edn" -M -m snlib.cli "$@"
