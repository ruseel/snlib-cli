#!/usr/bin/env bash
set -euo pipefail

set_default() {
  local var_name="$1"
  local default_value="$2"
  if [[ -z "${!var_name+x}" || -z "${!var_name}" ]]; then
    printf -v "$var_name" '%s' "$default_value"
  fi
}

prepend_path_if_exists() {
  local bin_dir="$1"
  if [[ -d "$bin_dir" ]]; then
    export PATH="$bin_dir:$PATH"
  fi
}

ensure_cmd() {
  local cmd="$1"
  local install_hint="$2"
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "ERROR: $cmd command not found. $install_hint" >&2
    exit 127
  fi
}

# NOTE: This default repo URL still points at a maintainer-specific SSH remote.
# Replace it with a public clone URL before publishing to ClawHub.
set_default SNLIB_GITHUB_REPO "git@github-ruseel:ruseel/2026-02-27-snlib-cli.git"
# This launcher intentionally fetches source via tools.deps instead of bundling
# compiled artifacts into the skill. That keeps the published skill small and
# reviewable, but the maintainer must repin these values for each release.
set_default SNLIB_GIT_TAG "20260304"
set_default SNLIB_GIT_SHA "7383431969192e7c875904a7960726add6cf3c0b"
# Optional complete -Sdeps override for dev/testing.
# Example: SNLIB_DEPS_EDN='{:deps {...}}'
set_default SNLIB_DEPS_EDN ""
set_default SNLIB_USE_LOCAL_CHECKOUT "1"

# OpenClaw runs may not load interactive shell PATH.
# Auto-discover local installs used in this workspace.
if ! command -v java >/dev/null 2>&1; then
  if [[ -x "$HOME/.local/jdk/bin/java" ]]; then
    set_default JAVA_HOME "$HOME/.local/jdk"
    prepend_path_if_exists "$JAVA_HOME/bin"
  fi
fi

if ! command -v clojure >/dev/null 2>&1; then
  prepend_path_if_exists "$HOME/.local/bin"
fi

ensure_cmd java "Install a JDK first (or set JAVA_HOME/PATH)."
ensure_cmd clojure "Install Clojure CLI first (or add ~/.local/bin to PATH)."

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd -- "${script_dir}/../../.." && pwd)"

if [[ "${SNLIB_USE_LOCAL_CHECKOUT}" != "0" ]] \
  && [[ -f "${repo_root}/deps.edn" ]] \
  && [[ -f "${repo_root}/src/snlib/cli.clj" ]]; then
  cd "${repo_root}"
  exec clojure -M -m snlib.cli "$@"
fi

if [[ -n "${SNLIB_DEPS_EDN}" ]]; then
  deps_edn="${SNLIB_DEPS_EDN}"
else
  if [[ -z "${SNLIB_GIT_TAG}" || -z "${SNLIB_GIT_SHA}" ]]; then
    echo "ERROR: SNLIB_GIT_TAG and SNLIB_GIT_SHA must both be set for tools.deps git deps." >&2
    exit 2
  fi
  # Keep :git/url explicit because this repo name does not match io.github.ruseel/snlib-cli.
  # Tradeoff: the published skill bundle is not self-contained; it shells out to
  # Clojure and resolves this repo at runtime rather than shipping source/binaries.
  deps_edn="{:deps {io.github.ruseel/snlib-cli {:git/url \"${SNLIB_GITHUB_REPO}\" :git/tag \"${SNLIB_GIT_TAG}\" :git/sha \"${SNLIB_GIT_SHA}\"}}}"
fi

exec clojure -Sdeps "$deps_edn" -M -m snlib.cli "$@"
