#!/usr/bin/env bash
set -euo pipefail

SNLIB_GITHUB_REPO="${SNLIB_GITHUB_REPO:-https://github.com/ruseel/snlib-cli}"
SNLIB_GIT_TAG="${SNLIB_GIT_TAG:-v0.1.0}"

# Telegram/OpenClaw runs may not load interactive shell PATH.
# Auto-discover local installs used in this workspace.
if ! command -v java >/dev/null 2>&1; then
  if [[ -x "$HOME/.local/jdk/bin/java" ]]; then
    export JAVA_HOME="${JAVA_HOME:-$HOME/.local/jdk}"
    export PATH="$JAVA_HOME/bin:$PATH"
  fi
fi

if ! command -v clojure >/dev/null 2>&1; then
  if [[ -x "$HOME/.local/bin/clojure" ]]; then
    export PATH="$HOME/.local/bin:$PATH"
  fi
fi

if ! command -v java >/dev/null 2>&1; then
  echo "ERROR: java command not found. Install a JDK first (or set JAVA_HOME/PATH)." >&2
  exit 127
fi

if ! command -v clojure >/dev/null 2>&1; then
  echo "ERROR: clojure command not found. Install Clojure CLI first (or add ~/.local/bin to PATH)." >&2
  exit 127
fi

if [[ -z "${SNLIB_GIT_TAG}" ]]; then
  echo "ERROR: SNLIB_GIT_TAG must be set. This launcher only supports tag-based refs (SHA/main not allowed)." >&2
  exit 2
fi

deps_edn="{:deps {io.github.ruseel/snlib-cli {:git/url \"${SNLIB_GITHUB_REPO}\" :git/tag \"${SNLIB_GIT_TAG}\"}}}"

exec clojure -Sdeps "$deps_edn" -M -m snlib.cli "$@"
